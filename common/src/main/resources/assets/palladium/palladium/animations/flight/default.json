{
  "root": {
    "x_rot": "query.flight_pitch()",
    "z_rot": "query.flight_roll()"
  },
  "head": {
    "x_rot": "value - query.flight_pitch()"
  },
  "right_arm": {
    "x_rot": "value + query.flight_limb_pitch()",
    "z_rot": "math.max(0, value - query.flight_limb_roll())"
  },
  "left_arm": {
    "x_rot": "value + query.flight_limb_pitch()",
    "z_rot": "math.min(0, value - query.flight_limb_roll())"
  },
  "right_leg": {
    "x_rot": "value + query.flight_limb_pitch()",
    "z_rot": "math.max(0, value - query.flight_limb_roll())"
  },
  "left_leg": {
    "x_rot": "value + query.flight_limb_pitch()",
    "z_rot": "math.min(0, value - query.flight_limb_roll())"
  }
}