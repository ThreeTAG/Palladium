{
  "root": {
    "x_rot": "palladium.flight_pitch()",
    "z_rot": "palladium.flight_yaw()"
  },
  "head": {
    "x_rot": "value - (palladium.flight_pitch())"
  },
  "right_arm": {
    "x_rot": "value + palladium.swinging_right_arm_pitch()",
    "z_rot": "math.max(0, value - palladium.flight_limb_roll())"
  },
  "left_arm": {
    "x_rot": "value + palladium.swinging_left_arm_pitch()",
    "z_rot": "math.min(0, value - palladium.flight_limb_roll())"
  },
  "right_leg": {
    "x_rot": "value + palladium.flight_limb_pitch()",
    "z_rot": "math.max(0, value - palladium.flight_limb_roll())"
  },
  "left_leg": {
    "x_rot": "value + palladium.flight_limb_pitch()",
    "z_rot": "math.min(0, value - palladium.flight_limb_roll())"
  }
}